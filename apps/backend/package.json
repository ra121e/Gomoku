{
  "name": "transcendence-backend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "bun server.ts",
    "build": "bun run prisma:generate && next build",
    "start": "bun server.ts",
    "prisma:generate": "rm -rf generated/prisma && bunx --bun prisma generate",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev",
    "prisma:migrate:deploy": "bunx --bun prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "dotenv": "17.4.0",
    "next": "16.2.2",
    "pg": "8.20.0",
    "prisma": "7.6.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "socket.io": "4.8.1"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "typescript": "5.8.3"
  }
}
