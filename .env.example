# Copy this file to .env and fill in the values before running docker compose up.
# .env is gitignored and must never be committed.

# PostgreSQL credentials
POSTGRES_DB=transcendence
POSTGRES_USER=transcendence
POSTGRES_PASSWORD=change_me_please

# Use localhost when running Prisma or the backend directly on your host.
DATABASE_URL=postgresql://transcendence:change_me_please@localhost:5432/transcendence?schema=public

# Better Auth
BETTER_AUTH_SECRET=change_me_to_a_32_byte_random_secret
BETTER_AUTH_URL=http://localhost:3000
