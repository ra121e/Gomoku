{
  "name": "transcendence-tooling",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "prepare": "simple-git-hooks",
    "format": "bunx --bun prettier . --write",
    "format:check": "bunx --bun prettier . --check",
    "lint": "bun run lint:js && bun run lint:css",
    "lint:fix": "bun run lint:js:fix && bun run lint:css:fix",
    "lint:js": "bunx --bun eslint apps --cache",
    "lint:js:fix": "bunx --bun eslint apps --fix --cache",
    "lint:css": "bunx --bun stylelint \"apps/**/*.css\" --cache",
    "lint:css:fix": "bunx --bun stylelint \"apps/**/*.css\" --fix --cache"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bunx --bun eslint --fix",
      "bunx --bun prettier --write"
    ],
    "*.css": [
      "bunx --bun stylelint --fix",
      "bunx --bun prettier --write"
    ],
    "*.{json,md,mjs,yml,yaml}": "bunx --bun prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx --bun lint-staged"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "next": "16.2.2",
    "prettier": "3.8.1",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.57.2"
  }
}
