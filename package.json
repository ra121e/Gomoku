{
  "name": "transcendence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:realtime": "bun realtime/server.ts",
    "build": "bun run prisma:generate && next build",
    "build:next": "next build",
    "typecheck": "next typegen && tsc --noEmit",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:realtime": "bun realtime/server.ts",
    "realtime:drain-outbox": "bun --bun scripts/drain-realtime-outbox.ts",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev",
    "prisma:migrate:deploy": "bunx --bun prisma migrate deploy",
    "prisma:seed": "bunx --bun prisma db seed",
    "prepare": "simple-git-hooks",
    "format": "bunx --bun oxfmt --write .",
    "format:check": "bunx --bun oxfmt --check .",
    "lint": "bun run lint:js && bun run lint:css",
    "lint:fix": "bun run lint:js:fix && bun run lint:css:fix",
    "lint:js": "bunx --bun oxlint .",
    "lint:js:fix": "bunx --bun oxlint --fix .",
    "lint:css": "bunx --bun stylelint \"app/**/*.css\" --cache",
    "lint:css:fix": "bunx --bun stylelint \"app/**/*.css\" --fix --cache",
    "test": "bun test",
    "test:prisma:seed": "RUN_PRISMA_SEED_SMOKE=true bun test tests/integration/prisma-seed.test.ts",
    "test:redis:smoke": "RUN_REDIS_SMOKE=true bun test tests/integration/redis-smoke.test.ts",
    "test:e2e": "env -u NO_COLOR PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test",
    "test:e2e:debug": "env -u NO_COLOR PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HTML_OPEN=never playwright test --debug=cli",
    "test:e2e:ui": "env -u NO_COLOR PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --ui",
    "pw:cli": "bunx --bun @playwright/cli",
    "pw:install": "env -u NO_COLOR PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright install chromium firefox msedge"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.11",
    "@better-auth/redis-storage": "^1.6.11",
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@socket.io/bun-engine": "^0.1.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "nodemailer": "^8.0.9",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.12.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "brace-expansion": "5.0.6",
    "fast-uri": "3.1.2",
    "hono": "4.12.23",
    "ip-address": "10.2.0",
    "postcss": "8.5.15",
    "qs": "6.15.2",
    "ws": "8.21.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx --bun lint-staged"
  },
  "lint-staged": {
    "!(*.d).{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "bunx --bun oxlint --fix",
      "bunx --bun oxfmt --write"
    ],
    "*.{css,scss,less}": [
      "bunx --bun stylelint --fix",
      "bunx --bun oxfmt --write"
    ],
    "*.{json,jsonc,json5,md,mdx,html,yml,yaml,toml}": "bunx --bun oxfmt --write"
  },
  "packageManager": "bun@1.3.14"
}
