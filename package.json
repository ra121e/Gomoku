{
  "name": "transcendence",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:realtime": "bun realtime/server.ts",
    "build": "bun run prisma:generate && next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:realtime": "bun realtime/server.ts",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev",
    "prisma:migrate:deploy": "bunx --bun prisma migrate deploy",
    "prisma:seed": "bunx --bun prisma db seed",
    "prepare": "simple-git-hooks",
    "format": "bunx --bun prettier . --write",
    "format:check": "bunx --bun prettier . --check",
    "lint": "bun run lint:js && bun run lint:css",
    "lint:fix": "bun run lint:js:fix && bun run lint:css:fix",
    "lint:js": "bunx --bun eslint . --cache",
    "lint:js:fix": "bunx --bun eslint . --fix --cache",
    "lint:css": "bunx --bun stylelint \"app/**/*.css\" --cache",
    "lint:css:fix": "bunx --bun stylelint \"app/**/*.css\" --fix --cache"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bunx --bun eslint --fix",
      "bunx --bun prettier --write"
    ],
    "*.css": [
      "bunx --bun stylelint --fix",
      "bunx --bun prettier --write"
    ],
    "*.{json,md,mjs,yml,yaml}": "bunx --bun prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx --bun lint-staged"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@socket.io/bun-engine": "^0.1.0",
    "dotenv": "^17.4.2",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "^1.3.0",
    "@types/node": "^25.6.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/typescript-estree": "^8.58.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
