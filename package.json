{
  "name": "transcendence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:realtime": "bun realtime/server.ts",
    "build": "bun run prisma:generate && next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:realtime": "bun realtime/server.ts",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev",
    "prisma:migrate:deploy": "bunx --bun prisma migrate deploy",
    "prisma:seed": "bunx --bun prisma db seed",
    "prepare": "simple-git-hooks",
    "format": "bunx --bun oxfmt --write .",
    "format:check": "bunx --bun oxfmt --check .",
    "lint": "bun run lint:js && bun run lint:css",
    "lint:fix": "bun run lint:js:fix && bun run lint:css:fix",
    "lint:js": "bunx --bun oxlint .",
    "lint:js:fix": "bunx --bun oxlint --fix .",
    "lint:css": "bunx --bun stylelint \"app/**/*.css\" --cache",
    "lint:css:fix": "bunx --bun stylelint \"app/**/*.css\" --fix --cache",
    "test": "bun test"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@socket.io/bun-engine": "^0.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.2",
    "next-intl": "^4.9.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.5.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.9.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx --bun lint-staged"
  },
  "lint-staged": {
    "!(*.d).{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "bunx --bun oxlint --fix",
      "bunx --bun oxfmt --write"
    ],
    "*.{css,scss,less}": [
      "bunx --bun stylelint --fix",
      "bunx --bun oxfmt --write"
    ],
    "*.{json,jsonc,json5,md,mdx,html,yml,yaml,toml}": "bunx --bun oxfmt --write"
  },
  "packageManager": "bun@1.3.11"
}
